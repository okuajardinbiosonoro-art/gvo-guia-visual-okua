# URL base del servidor GVO (apps/server)
#
# En desarrollo local: dejar vacío para usar el proxy de Vite (recomendado).
#   El proxy reenvía /api/* y /health hacia http://localhost:3001 automáticamente.
#
# En producción o acceso directo desde red local sin proxy:
#   usar la IP real del servidor Windows y el puerto configurado.
#   Ejemplo: VITE_API_BASE_URL=http://192.168.1.100:3001
#
# Copia este archivo como .env.local (ignorado por git) y ajusta según tu entorno.
VITE_API_BASE_URL=
