{
  "name": "gvo-guia-visual-okua",
  "private": true,
  "version": "0.9.0-rc.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:server": "npm run dev --workspace=apps/server",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=apps/web && npm run build --workspace=apps/server",
    "typecheck": "npm run typecheck --workspace=packages/shared && npm run typecheck --workspace=apps/web && npm run typecheck --workspace=apps/server",
    "smoke:journey": "node scripts/smoke-journey.mjs",
    "qr:generate": "node scripts/generate-qr-assets.mjs",
    "pilot:soak": "node scripts/pilot-soak-test.mjs",
    "pilot:concurrency": "node scripts/pilot-concurrency-probe.mjs",
    "prepare:field-release": "node scripts/prepare-field-release.mjs",
    "autostart:install": "powershell -ExecutionPolicy Bypass -File scripts/install-gvo-autostart.ps1",
    "autostart:remove": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-gvo-autostart.ps1",
    "verify:local": "powershell -ExecutionPolicy Bypass -File scripts/verify-gvo-local.ps1",
    "start": "npm run start:local",
    "start:local": "powershell -ExecutionPolicy Bypass -File scripts/start-gvo.ps1",
    "start:windows": "npm run start:local"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "qrcode": "^1.5.4"
  }
}
